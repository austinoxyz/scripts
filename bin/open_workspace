#!/bin/bash

CLIENT_SCRIPT="/Code/500/build/client_500"
SERVER_SCRIPT="/Code/500/build/server_500"
SLEEP=0.4

${HOME}${SERVER_SCRIPT} &

alacritty & sleep ${SLEEP}; xdotool key Meta_L+V
sleep ${SLEEP}; xdotool type "${HOME}${CLIENT_SCRIPT}"; xdotool key Return; 

alacritty & sleep ${SLEEP}; xdotool type "${HOME}${CLIENT_SCRIPT}"; xdotool key Return; 

alacritty & sleep ${SLEEP}; xdotool type "${HOME}${CLIENT_SCRIPT}"; xdotool key Return; 

alacritty & sleep ${SLEEP}; xdotool type "${HOME}${CLIENT_SCRIPT}"; xdotool key Return; 

#sleep 0.3; xdotool type "bg"; xdotool key Return; 
