#!/bin/sh
redshift_status_file="${XDG_CACHE_HOME:-$HOME/.cache}/redshift_status"

[ ! -f "$redshift_status_file" ] && echo "off" > "$redshift_status_file"

redshift_status="$(cat $redshift_status_file)"

if [ "$redshift_status" = "off" ]; then
    gamma="0.9:0.9:0.9"
    brightness="0.9"
    echo "on" > $redshift_status_file
else
    gamma="1:1:1"
    brightness="1"
    echo "off" > $redshift_status_file
fi

xrandr --output DP-0 --mode 1920x1080 --rate 60.00 --brightness $brightness --gamma $gamma --output DP-2 --right-of DP-0 --mode 1920x1080 --rate 1440.00 --brightness $brightness --gamma $gamma --crtc 1
