#!/bin/sh
. ${XDG_CONFIG_HOME:-$HOME/.config}/dmenu
bookmarks_file=${XDG_DATA_HOME:-$HOME/.local/share}/bookmarks.txt
selected_bookmark="$(cat ${bookmarks_file} | dmenu -F -c -i \
    -h 30                                                   \
    -bw $border_width                                       \
    -l 15                                                   \
    -m $monitor                                             \
    -p "select site:"                                       \
    -fn $font)"
[ ! -z $selected_bookmark ] && firefox -url $selected_bookmark

